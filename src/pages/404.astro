---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import WhatsAppButton from '../components/ui/WhatsAppButton.astro';
---

<BaseLayout
  title="Página não encontrada | Brasil DTF"
  description="A página que você procura não existe."
  noindex={true}
>
  <section class="bg-surface py-24 sm:py-32">
    <Container class="max-w-2xl text-center">
      <p class="font-display text-[clamp(4rem,18vw,9rem)] leading-none text-ink">404</p>
      <h1 class="font-display mt-2 text-[clamp(1.75rem,5vw,3rem)] leading-none">
        Essa página a gente não imprimiu
      </h1>
      <p class="mx-auto mt-4 max-w-md text-ink-muted">
        O link pode estar quebrado ou a página foi movida. Volte para o catálogo ou fale com a gente.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/#catalogo" variant="primary" size="lg">Ver máquinas</Button>
        <WhatsAppButton
          label="Falar no WhatsApp"
          variant="secondary"
          size="lg"
          contentName="404"
          contentCategory="404"
        />
      </div>
    </Container>
  </section>
</BaseLayout>
