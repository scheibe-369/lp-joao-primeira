---
import Container from '../../components/ui/Container.astro';

interface Testimonial {
  name: string;
  city: string;
  quote: string;
}

// 👤 Conteúdo a coletar com o cliente (nome + cidade + depoimento real).
// NÃO inventar depoimentos. Enquanto vazio, a seção não é renderizada.
const testimonials: Testimonial[] = [];
---

{
  testimonials.length > 0 && (
    <section class="bg-surface py-16 sm:py-20 lg:py-24">
      <Container>
        <header class="mb-10 max-w-2xl" data-reveal>
          <p class="eyebrow">Quem já compra com a gente</p>
          <h2 class="font-display mt-3 text-[clamp(2rem,5vw,3.25rem)] leading-none">
            Histórias de quem está faturando
          </h2>
        </header>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {testimonials.map((t, i) => (
            <figure
              class="flex flex-col rounded-xl border border-line bg-surface p-6 shadow-elev-1"
              data-reveal
              data-reveal-delay={i * 70}
            >
              <blockquote class="flex-1 text-ink">“{t.quote}”</blockquote>
              <figcaption class="mt-4 text-sm">
                <span class="font-semibold text-ink">{t.name}</span>
                <span class="text-ink-muted"> · {t.city}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </Container>
    </section>
  )
}
