---
// Banner LGPD (opt-in) que GATEIA a injeção do Meta Pixel. Esta é a ilha de JS
// "consent" — também carrega o Pixel após o aceite e dispara o evento Contact
// (delegação em [data-wa]). Ver PRD §6 regra 8 e §9 do manifesto de segurança.
---

<div
  id="cookie-banner"
  hidden
  role="dialog"
  aria-live="polite"
  aria-label="Aviso de privacidade"
  class="fixed inset-x-0 bottom-0 z-50 border-t border-white/10 bg-navy-deep/95 backdrop-blur-md"
  style="padding-bottom: env(safe-area-inset-bottom);"
>
  <div
    class="mx-auto flex max-w-content flex-col gap-4 px-4 py-4 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8"
  >
    <p class="text-sm leading-relaxed text-muted">
      Usamos cookies do Meta (Pixel) para medir a performance dos nossos anúncios. Você pode aceitar
      ou recusar. Saiba mais na nossa
      <a href="/politica-de-privacidade" class="font-semibold text-accent underline-offset-2 hover:underline"
        >Política de Privacidade</a
      >.
    </p>
    <div class="flex shrink-0 gap-3">
      <button
        type="button"
        data-reject
        class="min-h-[44px] rounded-full border border-white/30 px-5 py-2 text-sm font-semibold text-white transition-colors hover:bg-white/5"
        >Recusar</button
      >
      <button
        type="button"
        data-accept
        class="min-h-[44px] rounded-full bg-accent px-5 py-2 text-sm font-semibold text-accent-ink transition-transform hover:scale-[1.02]"
        >Aceitar</button
      >
    </div>
  </div>
</div>

<script>
  import { getConsent, setConsent } from '../../lib/consent';
  import { initPixel, track } from '../../lib/analytics/pixel';

  const PIXEL_ID = import.meta.env.PUBLIC_META_PIXEL_ID ?? '';
  const banner = document.getElementById('cookie-banner');

  function enablePixel(): void {
    if (PIXEL_ID) {
      initPixel(PIXEL_ID);
    } else if (import.meta.env.PROD) {
      console.warn('[Pixel] PUBLIC_META_PIXEL_ID ausente em produção — Pixel não carregado.');
    }
  }

  // tracker global definitivo (substitui o stub do <head>); só envia com consentimento
  window.bdtfTrack = (event: string, params?: Record<string, unknown>) => {
    if (getConsent() !== 'granted') return;
    track(event, params);
  };

  function flushQueued(): void {
    const w = window as unknown as { __bdtfQ?: Array<[string, Record<string, unknown>?]> };
    if (Array.isArray(w.__bdtfQ)) {
      for (const args of w.__bdtfQ) window.bdtfTrack?.(args[0], args[1]);
      w.__bdtfQ = [];
    }
  }

  const consent = getConsent();
  if (consent === 'granted') {
    enablePixel();
    flushQueued();
  } else if (consent === null && banner) {
    banner.hidden = false;
  }

  banner?.querySelector('[data-accept]')?.addEventListener('click', () => {
    setConsent('granted');
    if (banner) banner.hidden = true;
    enablePixel(); // dispara PageView no init
    flushQueued();
  });

  banner?.querySelector('[data-reject]')?.addEventListener('click', () => {
    setConsent('denied');
    if (banner) banner.hidden = true;
  });

  // Delegação: qualquer clique em [data-wa] dispara Contact (com content_name).
  document.addEventListener('click', (e) => {
    const target = e.target as Element | null;
    const el = target?.closest?.('[data-wa]') as HTMLElement | null;
    if (!el) return;
    const id = el.getAttribute('data-wa-id');
    window.bdtfTrack?.('Contact', {
      content_name: el.getAttribute('data-wa-name') ?? undefined,
      content_category: el.getAttribute('data-wa-category') ?? undefined,
      content_ids: id ? [id] : undefined,
    });
  });
</script>
