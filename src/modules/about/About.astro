---
import { Image } from 'astro:assets';
import aboutImg from '../../assets/machines/c605-h6502/g2.webp';
import Container from '../../components/ui/Container.astro';
import WhatsAppButton from '../../components/ui/WhatsAppButton.astro';
import Icon from '../../components/ui/Icon.astro';

const bullets = [
  'Revenda especializada em máquinas e insumos DTF e UV-DTF.',
  'Suporte em português, em tempo real pelo WhatsApp.',
  'Treinamento incluso pra você operar desde o dia 1.',
  'Garantia e pós-venda de verdade.',
  'Insumos abertos (tinta, pó, filme) — você não fica refém de cartucho travado.',
];
---

<section id="sobre" class="scroll-mt-20 bg-surface py-16 sm:py-20 lg:py-24">
  <Container class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
    <div class="order-2 lg:order-1">
      <div data-reveal>
        <p class="eyebrow">Sobre a Brasil DTF</p>
        <h2 class="font-display mt-3 text-[clamp(2rem,5vw,3.5rem)] leading-none">
          Mais que uma máquina: um parceiro pra você produzir
        </h2>
      </div>
      <ul class="mt-6 space-y-3">
        {
          bullets.map((b, i) => (
            <li class="flex items-start gap-3" data-reveal data-reveal-delay={80 + i * 60}>
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent text-accent-ink">
                <Icon name="check" size={16} />
              </span>
              <span class="leading-relaxed text-ink-muted">{b}</span>
            </li>
          ))
        }
      </ul>
      <div class="mt-8" data-reveal data-reveal-delay="420">
        <WhatsAppButton
          label="Tirar dúvidas no WhatsApp"
          contentName="Sobre"
          contentCategory="about"
        />
      </div>
    </div>

    <div class="order-1 lg:order-2" data-reveal>
      <div class="overflow-hidden rounded-2xl border border-line shadow-elev-2">
        <Image
          src={aboutImg}
          alt="Peça estampada com tecnologia DTF"
          widths={[480, 720]}
          sizes="(min-width: 1024px) 45vw, 90vw"
          loading="lazy"
          class="aspect-[4/3] w-full object-cover"
        />
      </div>
    </div>
  </Container>
</section>
