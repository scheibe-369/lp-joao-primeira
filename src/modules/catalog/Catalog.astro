---
import Container from '../../components/ui/Container.astro';
import ProductCard from './ProductCard.astro';
import { machines } from '../../data/machines';
---

<section id="catalogo" class="scroll-mt-20 bg-surface-2 py-16 sm:py-20 lg:py-24">
  <Container>
    <header class="mb-8 max-w-2xl" data-reveal>
      <p class="eyebrow">Catálogo</p>
      <h2 class="font-display mt-3 text-[clamp(2rem,5vw,3.5rem)] leading-none">
        Escolha sua impressora
      </h2>
      <p class="mt-3 text-ink-muted">
        Da entrada A3 à industrial de 5 cabeças, mais a linha UV-DTF. Filtre por tipo:
      </p>
    </header>

    {/* Filtro CSS-only: radios são irmãos da grid p/ o seletor ~ funcionar */}
    <input class="sr-only" type="radio" name="filtro" id="f-all" checked />
    <input class="sr-only" type="radio" name="filtro" id="f-tex" />
    <input class="sr-only" type="radio" name="filtro" id="f-uv" />

    <div class="chips mb-8 flex flex-wrap gap-2" role="group" aria-label="Filtrar por tipo">
      <label for="f-all" class="chip">Todas</label>
      <label for="f-tex" class="chip">Têxtil</label>
      <label for="f-uv" class="chip">UV-DTF</label>
    </div>

    <div class="catalog-grid grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {machines.map((m) => <ProductCard machine={m} />)}
    </div>
  </Container>
</section>
