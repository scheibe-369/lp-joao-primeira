---
import Container from '../../components/ui/Container.astro';
import type { Machine } from '../../data/machines';

interface Props {
  machine: Machine;
}
const { machine } = Astro.props;
---

<section class="bg-navy py-14 sm:py-16">
  <Container>
    <h2 class="font-display text-[clamp(1.75rem,4vw,2.75rem)] leading-none" data-reveal>
      Especificações
    </h2>
    <dl class="mt-6 overflow-hidden rounded-2xl border border-white/10" data-reveal>
      {
        machine.specs.map((s, i) => (
          <div
            class:list={[
              'grid gap-0.5 px-4 py-3 sm:grid-cols-[260px_1fr] sm:gap-4',
              i % 2 === 1 ? 'bg-white/[0.02]' : '',
            ]}
          >
            <dt class="text-sm text-muted [overflow-wrap:anywhere]">{s.label}</dt>
            <dd class="text-sm font-medium text-white [overflow-wrap:anywhere]">{s.value}</dd>
          </div>
        ))
      }
    </dl>
    <p class="mt-4 text-xs text-muted">
      Especificações conforme o fabricante; sujeitas a alteração sem aviso. Imagens ilustrativas.
    </p>
  </Container>
</section>
