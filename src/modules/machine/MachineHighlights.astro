---
import Container from '../../components/ui/Container.astro';
import Icon from '../../components/ui/Icon.astro';
import type { Machine } from '../../data/machines';

interface Props {
  machine: Machine;
}
const { machine } = Astro.props;
---

<section class="border-t border-line bg-surface-2 py-14 sm:py-16">
  <Container>
    <h2 class="font-display text-[clamp(1.75rem,4vw,2.75rem)] leading-none" data-reveal>Destaques</h2>
    <ul class="mt-6 grid gap-4 sm:grid-cols-2">
      {
        machine.highlights.map((h, i) => (
          <li
            class="flex items-start gap-3 rounded-xl border border-line bg-surface p-4 shadow-elev-1"
            data-reveal
            data-reveal-delay={i * 60}
          >
            <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-accent text-accent-ink">
              <Icon name="check" size={16} />
            </span>
            <span class="text-sm leading-relaxed text-ink">{h}</span>
          </li>
        ))
      }
    </ul>
  </Container>
</section>
