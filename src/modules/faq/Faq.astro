---
import Container from '../../components/ui/Container.astro';
import WhatsAppButton from '../../components/ui/WhatsAppButton.astro';

// Respostas aceitam <strong> p/ destacar trechos-chave (negrito leve).
const faqs = [
  {
    q: 'O que é DTF?',
    a: 'DTF (<strong>Direct to Film</strong>) é a impressão num filme especial que depois é transferido pro tecido com calor. Estampa <strong>qualquer cor de tecido</strong>, com cores vivas e ótima durabilidade.',
  },
  {
    q: 'Preciso de experiência?',
    a: 'Não. Todas as máquinas saem com <strong>treinamento incluso</strong> pra você operar desde o primeiro dia.',
  },
  { q: 'Tem garantia?', a: 'Sim. Todas as impressoras têm <strong>garantia e suporte técnico</strong>.' },
  {
    q: 'Vocês dão suporte?',
    a: 'Sim — <strong>suporte em português pelo WhatsApp</strong>, em tempo real.',
  },
  {
    q: 'Dá pra parcelar?',
    a: 'Temos <strong>condições facilitadas</strong> de pagamento. Fale com a gente no WhatsApp pra ver a melhor opção pra você.',
  },
  {
    q: 'Qual a diferença de têxtil pra UV-DTF?',
    a: '<strong>Têxtil</strong> é pra estampar tecidos (camisetas, moletons). <strong>UV-DTF</strong> é pra superfícies rígidas e rótulos crystal (vidro, metal, plástico, acrílico, madeira).',
  },
  {
    q: 'Quais insumos eu preciso?',
    a: 'Tinta, pó de poliamida e filme PET — todos <strong>abertos</strong> (sem cartucho travado). A Brasil DTF fornece os insumos.',
  },
];

const guide = [
  { who: 'Começando agora', pick: 'L8180 XP600', slug: 'l8180-xp600' },
  { who: 'Pequeno negócio', pick: 'XF-400PRO A2', slug: 'xf-400pro-a2' },
  { who: 'Produção 60cm', pick: '702E C650SC / Z650-2', slug: '702e-c650sc' },
  { who: 'Alto volume', pick: 'C605 H6502', slug: 'c605-h6502' },
  { who: 'UV / rótulos', pick: 'XF-420S / XF-450S', slug: 'xf-420s' },
];
---

<section id="faq" class="scroll-mt-20 bg-surface py-16 sm:py-20 lg:py-24">
  <Container class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr]">
    <div data-reveal>
      <p class="eyebrow">Dúvidas frequentes</p>
      <h2 class="font-display mt-3 text-[clamp(2rem,5vw,3.25rem)] leading-none">Perguntas rápidas</h2>
      <div class="mt-6 space-y-1">
        {
          faqs.map((f) => (
            <details name="faq" class="faq-item group">
              <summary class="faq-summary flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-4 text-left [&::-webkit-details-marker]:hidden sm:px-5">
                <span class="font-medium text-ink-muted transition-colors group-open:font-semibold group-open:text-ink sm:text-lg">
                  {f.q}
                </span>
                <span class="faq-toggle" aria-hidden="true" />
              </summary>
              <p class="faq-answer px-4 pb-5 leading-relaxed text-ink-muted sm:px-5" set:html={f.a} />
            </details>
          ))
        }
      </div>
    </div>

    <aside data-reveal>
      <div class="card-dark on-dark p-6">
        <div class="relative">
          <h3 class="font-display text-2xl text-white">Qual máquina é pra você?</h3>
          <ul class="mt-4 space-y-1.5">
            {
              guide.map((g) => (
                <li>
                  <a
                    href={`/maquinas/${g.slug}`}
                    class="flex items-center justify-between gap-3 rounded-lg px-3 py-2.5 transition-colors hover:bg-white/10"
                  >
                    <span class="text-sm text-muted">{g.who}</span>
                    <span class="text-right text-sm font-semibold text-white">{g.pick}</span>
                  </a>
                </li>
              ))
            }
          </ul>
          <div class="mt-5">
            <WhatsAppButton
              label="Me ajuda a escolher"
              block
              contentName="FAQ — guia de escolha"
              contentCategory="faq"
            />
          </div>
        </div>
      </div>
    </aside>
  </Container>
</section>
