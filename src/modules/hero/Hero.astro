---
import { Image } from 'astro:assets';
import heroImg from '../../assets/hero/hero.png';
import Container from '../../components/ui/Container.astro';
import WhatsAppButton from '../../components/ui/WhatsAppButton.astro';
import Icon from '../../components/ui/Icon.astro';

const trust = ['Garantia + treinamento', 'Suporte por WhatsApp', 'Insumos abertos'] as const;
---

<section class="bg-surface overflow-x-clip">
  <Container
    class="relative grid items-center gap-10 py-14 sm:py-20 lg:grid-cols-2 lg:gap-12 lg:py-24"
  >
    <div>
      <p class="eyebrow">Impressoras DTF &amp; UV-DTF</p>
      <h1
        class="font-display mt-4 text-[clamp(2.5rem,8vw,5.25rem)] leading-[0.92] text-ink [overflow-wrap:anywhere]"
      >
        A máquina DTF certa pra você começar a <span
          class="box-decoration-clone rounded-[2px] bg-accent px-2 text-accent-ink">faturar</span
        >
      </h1>
      <p class="mt-5 max-w-xl text-base text-ink-muted sm:text-lg">
        Da iniciante A3 à industrial de 5 cabeças — todas as impressoras DTF e UV-DTF da Brasil DTF
        num lugar só, com suporte, treinamento e garantia.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <WhatsAppButton
          label="Falar no WhatsApp"
          size="lg"
          contentName="Hero"
          contentCategory="hero"
        />
        <a
          href="#catalogo"
          aria-label="Ver máquinas — catálogo"
          class="group inline-flex items-center gap-3 rounded-full border border-white/15 bg-navy/80 py-2 pl-6 pr-2 shadow-elev-3 backdrop-blur-md transition-[background-color,box-shadow] duration-200 hover:bg-navy/90"
        >
          <span class="text-left leading-tight">
            <span class="block text-base font-semibold text-white">Ver máquinas</span>
            <span class="block text-xs text-white/70">7 modelos</span>
          </span>
          <span
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-white text-navy transition-transform duration-200 group-hover:scale-105"
          >
            <Icon name="arrow-right" size={18} />
          </span>
        </a>
      </div>
      <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink-muted">
        {
          trust.map((t) => (
            <li class="flex items-center gap-2">
              <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-accent text-accent-ink">
                <Icon name="check" size={14} />
              </span>
              {t}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="relative isolate">
      <!-- luz amarela suave saindo de trás da foto (estática, decorativa) -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -inset-6 -z-10 rounded-[3rem] bg-accent/45 blur-3xl sm:-inset-8"
      >
      </div>
      <div
        class="overflow-hidden rounded-[2rem] border border-line bg-white shadow-[0_30px_70px_-22px_rgba(5,26,59,0.38)] ring-1 ring-black/5"
      >
        <Image
          src={heroImg}
          alt="Especialista da Brasil DTF ao lado das impressoras DTF e UV-DTF"
          widths={[480, 720, 960]}
          sizes="(min-width: 1024px) 45vw, 90vw"
          loading="eager"
          fetchpriority="high"
          class="aspect-square w-full object-cover"
        />
      </div>
    </div>
  </Container>
</section>
