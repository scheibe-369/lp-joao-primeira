---
import Container from '../../components/ui/Container.astro';
import WhatsAppButton from '../../components/ui/WhatsAppButton.astro';

interface Props {
  title?: string;
  subtitle?: string;
  message?: string;
  contentName?: string;
}
const {
  title = 'Pronto pra começar a faturar com DTF?',
  subtitle = 'Fale com a gente no WhatsApp: a gente te ajuda a escolher a máquina certa, tira suas dúvidas e passa as condições.',
  message,
  contentName = 'ContactBand',
} = Astro.props;
---

<section data-contactband class="bg-surface-2 py-16 sm:py-24">
  <Container>
    <div
      class="mx-auto max-w-4xl rounded-3xl border border-line-strong bg-surface px-8 py-14 text-center shadow-[0_34px_80px_-24px_rgba(5,26,59,0.34)] sm:px-16 sm:py-20"
      data-reveal
    >
      <span class="mx-auto mb-7 block h-1.5 w-16 rounded-full bg-accent" aria-hidden="true"></span>
      <h2 class="font-display mx-auto max-w-3xl text-[clamp(2.25rem,5.5vw,4rem)] leading-none text-ink">
        {title}
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-ink-muted">{subtitle}</p>
      <div class="mt-9 flex justify-center">
        <WhatsAppButton
          label="Falar no WhatsApp"
          size="lg"
          message={message}
          contentName={contentName}
          contentCategory="contactband"
        />
      </div>
    </div>
  </Container>
</section>
