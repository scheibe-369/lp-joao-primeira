---
import Container from '../../components/ui/Container.astro';
import WhatsAppButton from '../../components/ui/WhatsAppButton.astro';

interface Props {
  title?: string;
  subtitle?: string;
  message?: string;
  contentName?: string;
}
const {
  title = 'Pronto pra começar a faturar com DTF?',
  subtitle = 'Fale com a gente no WhatsApp: a gente te ajuda a escolher a máquina certa, tira suas dúvidas e passa as condições.',
  message,
  contentName = 'ContactBand',
} = Astro.props;
---

<section data-contactband class="bg-surface py-16 sm:py-20">
  <Container class="text-center">
    <h2
      class="font-display mx-auto max-w-3xl text-[clamp(2rem,5vw,3.5rem)] leading-none text-ink"
      data-reveal
    >
      {title}
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-ink-muted" data-reveal data-reveal-delay="80">{subtitle}</p>
    <div class="mt-8 flex justify-center" data-reveal data-reveal-delay="160">
      <WhatsAppButton
        label="Falar no WhatsApp"
        size="lg"
        message={message}
        contentName={contentName}
        contentCategory="contactband"
      />
    </div>
  </Container>
</section>
